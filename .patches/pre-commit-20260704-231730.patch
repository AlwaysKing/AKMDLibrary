+func (m *Manager) SaveAttachment(sessionID, originalFilename string, data []byte) (attachmentID, storedFilename string, err error) {
+	sess := m.SessionByID(sessionID)
+	if sess == nil {
+		return "", "", fmt.Errorf("session not found: %s", sessionID)
+	}
