# 本地调试环境变量
# 用法：cp .env.example .env，然后 go run ./cmd/server 会自动读取
# godotenv.Load() 会静默加载项目根的 .env，没文件不报错

# 服务端口（前端 vite 代理到这个端口）
PORT=8801

# 文档库目录：本地用相对路径避免 /app/... 的权限问题
# 默认会创建在项目根的 userdata/docs 下，不与项目源码冲突
DOCS_DIR=../userdata/docs

# 数据目录（SQLite + 上传的图标/封面等）
DATA_DIR=../userdata/data

# 前端构建产物目录（调试时一般用 vite dev，不读这个；保留给后端 SPA fallback）
FRONTEND_DIST=../frontend/dist

# JWT 密钥：本地开发随便填，生产必须改成随机长字符串（openssl rand -hex 32）
JWT_SECRET=dev-secret-change-me
